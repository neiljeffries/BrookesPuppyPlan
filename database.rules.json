{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('roles').child('admin').val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('roles').child('admin').val() === true)",
        "roles": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('roles').child('admin').val() === true",
          "admin": {
            ".validate": "root.child('users').child(auth.uid).child('roles').child('admin').val() === true"
          },
          "user": {
            ".validate": "newData.isBoolean()"
          }
        },
        "reminders": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        },
        "fcmTokens": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "notes": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "chats": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "settings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
